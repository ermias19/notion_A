NOTION_API_KEY=replace_with_new_secret
NOTION_DATABASE_ID=replace_with_database_id

# Optional settings
NOTION_API_VERSION=2025-09-03
TIMEZONE=Europe/Rome
TASK_TITLE_TEMPLATE=Daily Task - {date}
DATE_LABEL_FORMAT=%Y-%m-%d

# Optional: set if auto-detection chooses the wrong property name
# NOTION_DATE_PROPERTY=Date

# Optional: put the task in a status column each day
# NOTION_STATUS_PROPERTY=Status
# NOTION_STATUS_VALUE=Next Up
